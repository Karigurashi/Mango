{
  "name": "qoder-chat",
  "displayName": "Qoder Chat",
  "description": "AI-powered chat panel for VS Code — ReAct Agent with streaming, model switching, and built-in MCP bridge for VSCode API access",
  "version": "1.0.0",
  "publisher": "qoder",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Chat", "AI"],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "qoder-chat.open",
        "title": "Open Qoder Chat"
      },
      {
        "command": "qoder-chat.focusInput",
        "title": "Focus Chat Input"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "qoder-chat-sidebar",
          "title": "Qoder Chat",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "qoder-chat-sidebar": [
        {
          "type": "webview",
          "id": "qoderChatView",
          "name": "Chat"
        }
      ]
    }
  },
  "scripts": {
    "package": "vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.0.0"
  }
}
